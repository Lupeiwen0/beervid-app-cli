{
  "name": "beervid-app-cli",
  "version": "0.2.5",
  "description": "BEERVID App CLI — TikTok video publish, account auth, and data query",
  "repository": {
    "type": "git",
    "url": "https://github.com/Lupeiwen0/beervid-app-cli"
  },
  "type": "module",
  "types": "dist/index.d.ts",
  "engines": {
    "node": ">=22.0.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    }
  },
  "bin": {
    "beervid": "dist/cli.mjs"
  },
  "files": [
    "dist/",
    "skills/",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "sync:skill-version": "node scripts/sync-skill-version.mjs",
    "version": "npm run sync:skill-version",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "cac": "^6.7.14"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.1"
  },
  "keywords": [
    "beervid",
    "tiktok",
    "cli",
    "video",
    "open-api"
  ],
  "license": "MIT"
}
